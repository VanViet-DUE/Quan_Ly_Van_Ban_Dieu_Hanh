    usecase "Yeu cau chinh sua van ban di" as UC_RequestRevision
    usecase "Hoan thanh chinh sua van ban di" as UC_FinishRevision
    usecase "Dang ky van ban di" as UC_RegisterOutgoing
    usecase "Cap so van ban di" as UC_NumberOutgoing
