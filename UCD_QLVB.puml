    usecase "Xem chi tiet phat hanh ben ngoai" as UC_ViewExternalDispatchDetail
  }

  package "5. Quan ly cong viec va xu ly" {
    usecase "Xem danh sach van ban can phan cong" as UC_ViewAssignQueue
    usecase "Tim kiem van ban can phan cong" as UC_SearchAssignQueue
    usecase "Xem chi tiet van ban can phan cong" as UC_ViewAssignQueueDetail
    usecase "Phan cong xu ly van ban" as UC_AssignProcessing
    usecase "Xem danh sach van ban da phan cong" as UC_ViewAssignedList
    usecase "Tim kiem van ban da phan cong" as UC_SearchAssignedList
    usecase "Xem chi tiet van ban da phan cong" as UC_ViewAssignedDetail
    usecase "Theo doi tien do xu ly" as UC_ProgressTracking
    usecase "Xem chi tiet tien do xu ly" as UC_ProgressDetail
    usecase "Tim kiem tien do xu ly" as UC_SearchProgress
    usecase "Xem cong viec ca nhan" as UC_ViewPersonalTaskList
    usecase "Tim kiem cong viec ca nhan" as UC_SearchPersonalTask
    usecase "Xem chi tiet cong viec ca nhan" as UC_ViewPersonalTaskDetail
    usecase "Cap nhat tien do xu ly ca nhan" as UC_UpdatePersonalProgress
    usecase "Chuyen phan cong xu ly" as UC_ReassignTask
    usecase "Xem danh sach van ban tra lai" as UC_ViewReturnedList
    usecase "Tim kiem van ban tra lai" as UC_SearchReturned
    usecase "Xem chi tiet van ban tra lai" as UC_ViewReturnedDetail
  }

  package "6. Quan tri he thong" {
    usecase "Xem danh sach nguoi dung" as UC_ViewUserList
    usecase "Tim kiem nguoi dung" as UC_SearchUsers
    usecase "Xem chi tiet tai khoan nguoi dung" as UC_ViewUserDetail
    usecase "Them tai khoan giao vien" as UC_CreateUser
    usecase "Cap nhat tai khoan giao vien" as UC_UpdateUser
    usecase "Reset mat khau nguoi dung" as UC_ResetPassword
    usecase "Xem danh sach phan quyen nguoi dung" as UC_ViewRoleList
    usecase "Cap nhat phan quyen nguoi dung" as UC_UpdateRole
    usecase "Xem danh sach noi nhan" as UC_ViewRecipientList
    usecase "Tim kiem noi nhan" as UC_SearchRecipients
    usecase "Xem chi tiet noi nhan" as UC_ViewRecipientDetail
    usecase "Them noi nhan" as UC_CreateRecipient
    usecase "Cap nhat noi nhan" as UC_UpdateRecipient
    usecase "Xem danh sach mau van ban" as UC_ViewTemplateList
    usecase "Tim kiem mau van ban" as UC_SearchTemplates
    usecase "Xem chi tiet mau van ban" as UC_ViewTemplateDetail
    usecase "Them mau van ban" as UC_CreateTemplate
    usecase "Cap nhat mau van ban" as UC_UpdateTemplate
    usecase "Xoa mau van ban" as UC_DeleteTemplate
  }
}

