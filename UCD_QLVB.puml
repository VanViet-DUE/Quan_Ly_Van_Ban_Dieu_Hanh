@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

title Use Case Diagram Chi Tiet - He thong Quan ly Van ban

actor "Van thu" as VanThu
actor "Hieu truong" as HieuTruong
actor "Pho hieu truong" as PhoHieuTruong
actor "To truong" as ToTruong

rectangle "He thong Quan ly Van ban" {

  package "1. Xac thuc va ho so" {
    usecase "Dang nhap" as UC_Login
    usecase "Dang xuat" as UC_Logout
    usecase "Cap nhat ho so ca nhan" as UC_Profile
    usecase "Doi mat khau" as UC_ChangePassword
  }

  package "2. Theo doi va tra cuu chung" {
    usecase "Theo doi tinh trang van ban" as UC_StatusTracking
    usecase "Tim kiem van ban" as UC_SearchDocs
    usecase "Loc van ban theo trang thai/\nloai/muc do" as UC_FilterDocs
    usecase "Xem danh sach van ban" as UC_ViewDocList
    usecase "Xem chi tiet van ban" as UC_ViewDocDetail
    usecase "Xem tep dinh kem van ban" as UC_ViewAttachments
  }

  package "3. Van ban den" {
    usecase "Xem danh sach van ban den" as UC_ViewIncomingList
    usecase "Tim kiem van ban den" as UC_SearchIncoming
    usecase "Loc van ban den" as UC_FilterIncoming
    usecase "Xem chi tiet van ban den" as UC_ViewIncomingDetail
    usecase "Dang ky van ban den" as UC_RegisterIncoming
    usecase "Cap nhat van ban den" as UC_UpdateIncoming
    usecase "Ban hanh noi bo van ban den" as UC_InternalIncoming
  }

  package "4. Van ban di" {
    usecase "Xem danh sach van ban di" as UC_ViewOutgoingList
